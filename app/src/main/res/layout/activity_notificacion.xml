<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NotificacionActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">


            <!-- EJERCICIO 1: TOAST -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="@android:color/holo_blue_light"
                android:layout_marginBottom="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ejercicio 1: Toast"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/editTextToast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Escribe algo"
                    android:padding="12dp"/>

                <Button
                    android:id="@+id/buttonToast"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mostrar Toast"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>


            <!-- EJERCICIO 2: SNACKBAR + LISTA DE TAREAS -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="@android:color/holo_green_light"
                android:layout_marginBottom="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ejercicio 2: Snackbar"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/editTextSnackbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Escribe una tarea"
                    android:padding="12dp"/>

                <Button
                    android:id="@+id/buttonSnackbar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Añadir tarea"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:id="@+id/textViewLista"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text=""/>
            </LinearLayout>


            <!-- EJERCICIO 3: DIÁLOGOS DE SELECCIÓN (COLOR / TAMAÑO) -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="@android:color/holo_orange_light"
                android:layout_marginBottom="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ejercicio 3: Diálogos de selección"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/buttonColor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Color"
                        android:layout_marginEnd="12dp"/>

                    <Button
                        android:id="@+id/buttonTamano"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tamaño"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/textoEjemplo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:padding="12dp"
                    android:background="#FFFFFF"
                    android:textColor="#000000"
                    android:text="Párrafo 1: Aquí puedes poner cualquier texto de ejemplo para modificar su color y tamaño.\n\nPárrafo 2: Este texto cambiará según la opción seleccionada en los diálogos de color y tamaño."/>
            </LinearLayout>

            <!-- EJERCICIO 4: NOTIFICACIONES -->

            <!-- EJERCICIO 4: NOTIFICACIONES -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="@android:color/holo_red_light"
                android:layout_marginBottom="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ejercicio 4: Notificaciones"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <Button
                        android:id="@+id/buttonIniciar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Iniciar"
                        android:layout_marginEnd="12dp"/>

                    <Button
                        android:id="@+id/buttonDetener"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detener"/>
                </LinearLayout>

                <!-- TextView para mostrar contador en la app -->
                <TextView
                    android:id="@+id/textViewContador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tareas iniciadas: 0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
